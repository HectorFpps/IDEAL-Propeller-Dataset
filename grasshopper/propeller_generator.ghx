            <chunk name="Object" index="87">
              <items count="2">
                <item name="GUID" type_name="gh_guid" type_code="9">a9a8ebd2-fff5-4c44-a8f5-739736d129ba</item>
                <item name="Name" type_name="gh_string" type_code="10">C# Script</item>
              </items>
              <chunks count="1">
                <chunk name="Container">
                  <items count="11">
                    <item name="AdditionalSource" type_name="gh_string" type_code="10">

</item>
                    <item name="CustomUsing" type_name="gh_bool" type_code="1">true</item>
                    <item name="Description" type_name="gh_string" type_code="10">A C#.NET scriptable component</item>
                    <item name="Hidden" type_name="gh_bool" type_code="1">true</item>
                    <item name="InstanceGuid" type_name="gh_guid" type_code="9">ac42f83c-8faf-47f0-95d2-f4554623a23d</item>
                    <item name="Name" type_name="gh_string" type_code="10">C# Script</item>
                    <item name="NickName" type_name="gh_string" type_code="10">C#</item>
                    <item name="OutParameter" type_name="gh_bool" type_code="1">true</item>
                    <item name="ReferenceCount" type_name="gh_int32" type_code="3">0</item>
                    <item name="ScriptSource" type_name="gh_string" type_code="10">
 List&lt;Brep&gt; textBodies = new List&lt;Brep&gt;();
    Curve[] textCurvs = Curve.CreateTextOutlines(textIn, "Arial", 3, 0, true, planeIn, 7, 0.1);

    // --------- Center Text -------------------------------

    // Calculate bounding box of all curves
    BoundingBox bbox = BoundingBox.Empty;
    foreach (Curve crv in textCurvs)
        bbox.Union(crv.GetBoundingBox(true));

    // Find center of bounding box
    Point3d center = bbox.Center;

    // Compute translation vector to move center to plane origin
    Vector3d translation = planeIn.Origin - center;

    // Move curves to center them
    for (int i = 0; i &lt; textCurvs.Length; i++)
        textCurvs[i].Translate(translation);

    // ----------------------------------------

    Vector3d dirVec = planeIn.Normal;


      //Vector3d extrudeDir = new Vector3d(dirVec.X * -1, dirVec.Y * -1, dirVec.Z * -1);
      dirVec.Reverse();

      foreach(Curve crv in textCurvs)
      {
        double extrudeDist = 1;

        Extrusion ribBody = Extrusion.Create(crv, extrudeDist, true);
        ribBody.SetPathAndUp(crv.PointAtStart, crv.PointAtEnd, dirVec);
        Brep closedRib = ribBody.ToBrep();

        Extrusion ribBodyB = Extrusion.Create(crv, -1 * extrudeDist, true);
        ribBodyB.SetPathAndUp(crv.PointAtStart, crv.PointAtEnd, dirVec);
        Brep closedRibB = ribBodyB.ToBrep();

        textBodies.Add(closedRib);
        textBodies.Add(closedRibB);
      }
      text = textBodies;




</item>
